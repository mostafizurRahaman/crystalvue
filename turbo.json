{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        ".next/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": [
        ""
      ]
    },
    "type-check": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ""
      ]
    },
    "clean": {
      "cache": false
    },
    "format": {
      "outputs": [
        ""
      ]
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    }
  }
}